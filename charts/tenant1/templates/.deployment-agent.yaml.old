apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Release.Name }}-agent
  labels:
    app: {{ .Release.Name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ .Release.Name }}
  template:
    metadata:
      labels:
        app: {{ .Release.Name }}
    spec:
      containers:
      - name: research-agent
        image: "{{ .Values.image.agent.repository }}:{{ .Values.image.agent.tag }}"
        imagePullPolicy: {{ .Values.image.pullPolicy }}

        resources:
          requests:
            memory: "100Mi"
            cpu: "100m"
          limits:
            memory: "200Mi"
            cpu: "250m"

        # INJECTS THE DYNAMIC TENANT ARRAY AS JSON FOR THE WORKER
        env:
        - name: TENANTS_JSON
          value: {{ .Values.tenants | toJson | quote }}

        # CONFIGURATION: Injects remaining plain environment variables
        envFrom:
        - configMapRef:
            name: {{ .Release.Name }}-config

        # STORAGE: Connects to the host-shared SQLite database
        volumeMounts:
        - name: shared-db
          mountPath: /app/data

      volumes:
      - name: shared-db
        hostPath:
          path: /tmp/fde_data
          type: DirectoryOrCreate
